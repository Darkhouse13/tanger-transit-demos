# DeepSeek API key — used SERVER-SIDE ONLY (demo 1 extraction + demo 2 classification).
# Get one at https://platform.deepseek.com/ . Copy this file to .env and fill in the value.
# Never commit the real .env.
DEEPSEEK_API_KEY=

# Optional — HTTP port for the Fastify server (default: 8080)
# PORT=8080

# Optional — set to 1 to serve canned extraction/classification responses WITHOUT
# calling DeepSeek (offline demo safety net). The deterministic engine still runs,
# so HS codes, duty, VAT, landed cost and risk circuits are computed exactly as live.
# DEMO_OFFLINE=1
